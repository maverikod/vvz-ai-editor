# Copy to .env (project root or next to config.json). Do not commit .env.
#
# Config placeholders in config.json / config/ai_editor_container.json:
#   ${AI_EDITOR_ADVERTISED_HOST}       — server.advertised_host (MCP proxy / clients)
#   ${AI_EDITOR_REGISTRATION_HOST}     — MCP proxy registration host
#   ${AI_EDITOR_REGISTRATION_PORT}     — MCP proxy registration port (default: 3004)
#   ${AI_EDITOR_CODE_ANALYSIS_HOST}    — Code Analysis Server direct JSON-RPC host
#   ${AI_EDITOR_CODE_ANALYSIS_PORT}    — optional; CA port default in config JSON

# --- AI Editor network (required when config uses ${...} placeholders) ---
AI_EDITOR_ADVERTISED_HOST=192.168.254.28
AI_EDITOR_REGISTRATION_HOST=192.168.254.26
AI_EDITOR_REGISTRATION_PORT=3004
AI_EDITOR_CODE_ANALYSIS_HOST=192.168.254.28
# AI_EDITOR_CODE_ANALYSIS_PORT=15010

# --- PostgreSQL (legacy / optional) ---
CODE_ANALYSIS_POSTGRES_PASSWORD=

# Optional: superuser password for scripts/setup_postgres_code_analysis_db.sh
# POSTGRES_SUPERUSER_PASSWORD=
