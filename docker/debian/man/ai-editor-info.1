.TH AI-EDITOR-INFO 1 "@VERSION@" "ai-editor-docker" "User Commands"
.SH NAME
ai-editor-info \- display AI Editor Docker host integration summary
.SH SYNOPSIS
.B ai-editor-info
.SH DESCRIPTION
Prints host user, published port, configuration paths, Docker image reference,
and container/systemd status for the \fBai-editor-docker\fR package.
.SH SEE ALSO
.BR ai-editor-docker (1)
