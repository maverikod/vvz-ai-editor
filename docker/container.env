# Environment passed into the ai-editor container by docker/build.sh and docker/run.sh.
#
# Author: Vasiliy Zdanovskiy
# email: vasilyvz@gmail.com

CONFIG_FILE=ai_editor_container.json

DOCKER_DNS_DOMAIN=techsup.od.ua
DOCKER_DNS_NAME=ai-editor-server
NET_NAME=smart-assistant
IP_HOST_NUM=4
SECOND_DOCKER_NETWORK=ai-editor-net

# PostgreSQL password for ai_editor.database (required for DB commands).
# Override in container.env.local or /etc/default/ai-editor on production hosts.
# AI_EDITOR_POSTGRES_PASSWORD=
